generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Veiculo {
  id       Int       @id @default(autoincrement())
  placa    String    @unique
  modelo   String
  cor      String?
  ano      Int?
  estadias Estadia[]
}

model Estadia {
  id         Int       @id @default(autoincrement())
  entrada    DateTime  @default(now())
  saida      DateTime?
  valorHora  Float
  valorTotal Float?
  veiculoId  Int
  veiculo    Veiculo   @relation(fields: [veiculoId], references: [id])
}